---
/**
 * ContactForm.astro
 * =================
 * Drop-in contact form component. Handles Cap verification,
 * API submission, loading/success/error states, and rate limiting.
 *
 * Usage:
 *   <ContactForm />
 *
 * The form reads API_ENDPOINT, API_KEY, CAP_SITE_KEY, and
 * CAP_BASE_URL from src/config.ts. You do not need to pass any props.
 *
 * Styling: the component uses plain HTML with class names.
 * Override styles in global.css or scope them to .contact-form.
 */
import { API_ENDPOINT, API_KEY, CAP_SITE_KEY, CAP_BASE_URL } from "../config";

const capEndpoint = `${CAP_BASE_URL}/${CAP_SITE_KEY}/`;
---

<div class="contact-form-wrapper" id="contact-form-wrapper">
  {/* ── Form ─────────────────────────────────────────── */}
  <form
    id="contact-form"
    class="contact-form"
    novalidate
    data-endpoint={API_ENDPOINT}
    data-api-key={API_KEY}
  >
    <div class="form-group">
      <label for="cf-name">Name <span class="required">*</span></label>
      <input type="text" id="cf-name" name="name" required autocomplete="name" />
    </div>

    <div class="form-group">
      <label for="cf-email">Email <span class="required">*</span></label>
      <input type="email" id="cf-email" name="email" required autocomplete="email" />
    </div>

    <div class="form-group">
      <label for="cf-message">Message <span class="required">*</span></label>
      <textarea
        id="cf-message"
        name="message"
        required
        rows="5"
        maxlength="5000"
      ></textarea>
    </div>

    {/* Cap widget */}
    <cap-widget data-cap-api-endpoint={capEndpoint}></cap-widget>

    <button type="submit" id="cf-submit" class="form-submit">
      Send Message
    </button>

    {/* Inline error messages */}
    <div id="cf-error" class="form-status form-status--error" role="alert" aria-live="polite"></div>
  </form>

  {/* ── Success state (hidden by default) ────────────── */}
  <div id="cf-success" class="form-success" hidden>
    <p>Thank you! Your message has been sent. We'll get back to you soon.</p>
  </div>
</div>

<script>
  function initContactForm() {
    const form = document.getElementById("contact-form") as HTMLFormElement | null;
    const submitBtn = document.getElementById("cf-submit") as HTMLButtonElement | null;
    const errorDiv = document.getElementById("cf-error") as HTMLDivElement | null;
    const successDiv = document.getElementById("cf-success") as HTMLDivElement | null;
    const wrapper = document.getElementById("contact-form-wrapper");

    if (!form || !submitBtn || !errorDiv || !successDiv) return;

    const endpoint = form.dataset.endpoint!;
    const apiKey = form.dataset.apiKey!;
    const capWidget = form.querySelector("cap-widget");

    function showError(msg: string) {
      errorDiv!.textContent = msg;
      errorDiv!.hidden = false;
    }

    function clearError() {
      errorDiv!.textContent = "";
      errorDiv!.hidden = true;
    }

    function setLoading(loading: boolean) {
      submitBtn!.disabled = loading;
      submitBtn!.textContent = loading ? "Sending…" : "Send Message";
    }

    function resetCap() {
      capWidget?.reset();
    }

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      clearError();

      // ── Client-side validation ──
      const name = (form.querySelector("#cf-name") as HTMLInputElement).value.trim();
      const email = (form.querySelector("#cf-email") as HTMLInputElement).value.trim();
      const message = (form.querySelector("#cf-message") as HTMLTextAreaElement).value.trim();

      if (!name || !email || !message) {
        showError("Please fill in all required fields.");
        return;
      }

      // ── Cap token ──
      const capInput = form.querySelector<HTMLInputElement>('[name="cap-token"]');
      const capToken = capInput?.value;

      if (!capToken) {
        showError("Please complete the verification challenge.");
        return;
      }

      // ── Submit ──
      setLoading(true);

      try {
        const res = await fetch(endpoint, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            api_key: apiKey,
            cap_token: capToken,
            submission: { name, email, message },
          }),
        });

        const data = await res.json();

        if (data.status === "ok") {
          // Show success, hide form
          form.reset();
          resetCap();
          form.hidden = true;
          successDiv.hidden = false;
        } else if (data.errors) {
          // Validation errors from the backend
          const messages = Object.entries(data.errors)
            .map(([field, errs]) => `${field}: ${(errs as string[]).join(", ")}`)
            .join(" · ");
          showError(messages);
          resetCap();
        } else {
          showError(data.message || "Something went wrong. Please try again.");
          resetCap();
        }
      } catch {
        showError("Network error. Please check your connection and try again.");
        resetCap();
      } finally {
        setLoading(false);
      }
    });
  }

  // Run on initial load and on Astro client-side navigations
  document.addEventListener("DOMContentLoaded", initContactForm);
  document.addEventListener("astro:page-load", initContactForm);
</script>
